# Supabase project (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Used for canonical/OG URLs, sitemap.xml and robots.txt. Falls back to
# http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
